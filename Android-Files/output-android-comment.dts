/dts-v1/;

/memreserve/	0x0000000009fe5000 0x0000000000018000;
/ {
	model = "Amlogic";
	amlogic-dt-id = "g12b_w400_b";
	compatible = "amlogic, g12b";
	interrupt-parent = <0x01>;
	#address-cells = <0x01>;
	#size-cells = <0x01>;

	// 内核启动参数，影响系统初始化行为
	chosen {
		bootargs = "
		// 指定 init 程序路径
		init=/init
		// 串口输出设置
		console=ttyS0,115200
		// 禁用串口挂起
		no_console_suspend
		// 启用早期串口调试
		earlycon=aml-uart,0xff803000
		// 启用崩溃日志记录
		ramoops.pstore_en=1
		// 设置记录大小
		ramoops.record_size=0x8000
	 	// 设置控制台日志大小
		ramoops.console_size=0x4000
		// HDR 显示策略
		hdr_policy=1
		// 启用 USB OTG 模式
		hdr_priority= otg_device=1
		// 设置重启模式
		reboot_mode_android=normal
		// logo 显示设置
		logo=osd0,loaded,0x3d800000
		// 帧缓冲区分辨率
		fb_width=1920 fb_height=1080
		// 视频输出设置
		vout=576cvbs,enable
		// LCD 面板类型与控制参数
		panel_type=lcd_2 lcd_ctrl=0x00000083
		// HDMI 输出设置
		hdmitx=,444,12bit hdmimode=1080p60hz hdmichecksum=0x00000000
		// Dolby Vision 设置
		dolby_vision_on=0
		// 分数帧率策略
		frac_rate_policy=1
		// 启用 EDID 读取
		hdmi_read_edid=1
		// CVBS 模式
		cvbsmode=576cvbs
		// OSD 和视频反转设置
		osd_reverse=0 video_reverse=0
		// IRQ 检查开关
		irq_check_en=0
		// SELinux 强制模式
		androidboot.selinux=enforcing
		// 是否首次启动
		androidboot.firstboot=0
		// 禁用 JTAG
		jtag=disable
		// 硬件平台标识
		androidboot.hardware=amlogic
		// 启动引导程序版本
		androidboot.bootloader=U-Boot 2015.01
		 // 基带信息
		androidboot.build.expect.baseband=N/A
		// 设备序列号
		androidboot.serialno=DZXB3P4213004936
		// MAC 地址
		mac=4C:91:7A:5F:F8:5A androidboot.mac=4C:91:7A:5F:F8:5A
		// OEM 自定义参数
		androidboot.oem.key1=ATV00104319
		// RPMB 安全存储状态
		androidboot.rpmb_state=1
		// 根文件系统挂载为只读
		ro
		// 等待根文件系统挂载
		rootwait
		// 跳过 initramfs 阶段
		skip_initramfs
		// DTBO 索引
		androidboot.dtbo_idx=0
		 // 指定根文件系统位置和构建类型
		--cmdline root=/dev/mmcblk0p18 buildvariant=user";
	};

	// 虚拟充电器
	dummy-charger {
		// 启用虚拟充电器设备（用于无电池设备）
		status = "okay";
		// 兼容字符串，匹配驱动
		compatible = "amlogic, dummy-charger";
	};

	// 虚拟电池
	dummy-battery {
		// 启用虚拟电池设备
		status = "okay";
		compatible = "amlogic, dummy-battery";
	};

	// 固件分区挂载信息
	firmware {

		android {
			compatible = "android,firmware";

			vbmeta {
				// Android Verified Boot 元数据配置
				compatible = "android,vbmeta";
				parts = "vbmeta,boot,system,vendor";
				by_name_prefix = "/dev/block";
			};

			fstab {
				compatible = "android,fstab";

				vendor {
					// 挂载 vendor 分区
					compatible = "android,vendor";
					dev = "/dev/block/vendor";
					type = "ext4";
					mnt_flags = "ro,barrier=1,inode_readahead_blks=8";
					fsmgr_flags = "wait";
				};

				product {
					// 挂载 product 分区
					compatible = "android,product";
					dev = "/dev/block/product";
					type = "ext4";
					mnt_flags = "ro,barrier=1,inode_readahead_blks=8";
					fsmgr_flags = "wait";
				};

				odm {
					// 挂载 odm 分区
					compatible = "android,odm";
					dev = "/dev/block/odm";
					type = "ext4";
					mnt_flags = "ro,barrier=1,inode_readahead_blks=8";
					fsmgr_flags = "wait";
				};
			};
		};
	};

	// 分区信息
	partitions {
		// 总分区数量（十六进制 0x11 = 十进制 17）
		parts = <0x11>;

		// 每个 part-x 都是一个分区的 phandle 引用
		part-0 = <0x02>;  // logo 分区
		part-1 = <0x03>;  // recovery 分区
		part-2 = <0x04>;  // misc 分区
		part-3 = <0x05>;  // dtbo 分区
		part-4 = <0x06>;  // cri_data 分区
		part-5 = <0x07>;  // param 分区
		part-6 = <0x08>;  // boot 分区
		part-7 = <0x09>;  // rsv 保留分区
		part-8 = <0x0a>;  // metadata 分区
		part-9 = <0x0b>;  // vbmeta 分区
		part-10 = <0x0c>; // tee 安全执行环境分区
		part-11 = <0x0d>; // vendor 分区
		part-12 = <0x0e>; // odm 分区
		part-13 = <0x0f>; // system 系统分区
		part-14 = <0x10>; // product 产品分区
		part-15 = <0x11>; // cache 缓存分区
		part-16 = <0x12>; // data 用户数据分区

		// partitions 节点的 phandle 引用
		phandle = <0xa4>;

		// 以下是每个分区的定义，包括名称、大小、掩码等
		logo {
			pname = "logo";              // 分区名称
			size = <0x00 0x800000>;      // 分区大小（8MB）
			mask = <0x01>;               // 掩码（访问权限或标志）
			phandle = <0x02>;            // 分区引用 ID
		};

		recovery {
			pname = "recovery";
			size = <0x00 0x1800000>;     // 24MB
			mask = <0x01>;
			phandle = <0x03>;
		};

		misc {
			pname = "misc";
			size = <0x00 0x800000>;      // 8MB
			mask = <0x01>;
			phandle = <0x04>;
		};

		dtbo {
			pname = "dtbo";              // 设备树覆盖分区
			size = <0x00 0x800000>;
			mask = <0x01>;
			phandle = <0x05>;
		};

		cri_data {
			pname = "cri_data";          // Critical data 分区
			size = <0x00 0x800000>;
			mask = <0x02>;
			phandle = <0x06>;
		};

		rsv {
			pname = "rsv";               // 保留分区
			size = <0x00 0x1000000>;
			mask = <0x01>;
			phandle = <0x09>;
		};

		metadata {
			pname = "metadata";          // 元数据分区
			size = <0x00 0x1000000>;
			mask = <0x01>;
			phandle = <0x0a>;
		};

		vbmeta {
			pname = "vbmeta";            // Verified Boot 元数据
			size = <0x00 0x200000>;      // 2MB
			mask = <0x01>;
			phandle = <0x0b>;
		};

		param {
			pname = "param";             // 参数配置分区
			size = <0x00 0x1000000>;     // 16MB
			mask = <0x02>;
			phandle = <0x07>;
		};

		boot {
			pname = "boot";              // 启动镜像分区
			size = <0x00 0x1000000>;     // 16MB
			mask = <0x01>;
			phandle = <0x08>;
		};

		tee {
			pname = "tee";              // TrustZone 分区
			size = <0x00 0x2000000>;    // 32MB
			mask = <0x01>;
			phandle = <0x0c>;
		};

		vendor {
			pname = "vendor";           // 供应商分区
			size = <0x00 0x40000000>;   // 1GB
			mask = <0x01>;
			phandle = <0x0d>;
		};

		odm {
			pname = "odm";              // OEM Device Manufacturer 分区
			size = <0x00 0x8000000>;    // 128MB
			mask = <0x01>;
			phandle = <0x0e>;
		};

		system {
			pname = "system";           // Android 系统分区
			size = <0x00 0x80000000>;   // 2GB
			mask = <0x01>;
			phandle = <0x0f>;
		};

		product {
			pname = "product";          // 产品定制分区
			size = <0x00 0x8000000>;    // 128MB
			mask = <0x01>;
			phandle = <0x10>;
		};

		cache {
			pname = "cache";            // 缓存分区
			size = <0x00 0x60000000>;   // 1.5GB
			mask = <0x02>;
			phandle = <0x11>;
		};

		data {
			pname = "data";             // 用户数据分区
			size = <0xffffffff 0xffffffff>;// 动态分配最大空间
			mask = <0x04>;
			phandle = <0x12>;
		};
	};

	// Amlogic G12B 平台上的 Mali GPU（Midgard 架构）的硬件资源、时钟、DVFS 配置等。
	bifrost {
		// 兼容字符串，匹配驱动（Mali-T60x/T6xx/Midgard 系列）
		compatible = "arm,malit60x\0arm,malit6xx\0arm,mali-midgard";

		// cooling-cells 表示散热设备的参数数量
		#cooling-cells = <0x02>;

		// GPU 寄存器地址映射（多个区域）
		reg = <0xffe40000 0x4000 0xffd01000 0x1000 0xff800000 0x1000 0xff63c000 0x1000 0xffd01000 0x1000>;

		// 中断控制器引用
		interrupt-parent = <0x01>;

		// GPU、MMU、JOB 的中断号及类型
		interrupts = <0x00 0xa0 0x04 0x00 0xa1 0x04 0x00 0xa2 0x04>;
		interrupt-names = "GPU\0MMU\0JOB";

		// PP（Pixel Processor）数量
		num_of_pp = <0x02>;

		// SCMPP（Shader Core Multi PP）配置
		sc_mpp = <0x01>;

		// GPU 时钟源配置（引用 clock-controller）
		clocks = <0x13 0x83 0x13 0x07>;
		clock-names = "gpu_mux\0gp0_pll";

		// DVFS 表引用（phandle）
		tbl = <0x14 0x15 0x16 0x17 0x18 0x18>;

		// 系统一致性设置（通常为 0 表示关闭）
		system-coherency = <0x00>;

		// 节点引用句柄
		phandle = <0xa5>;

		// 以下是不同频率下的 DVFS 配置（动态电压频率调整）
		clk125_cfg {
			clk_freq = <0x7735940>;           // 125MHz
			clk_parent = "fclk_div4";         // 时钟父源
			clkp_freq = <0x1dcd6500>;         // 父源频率（500MHz）
			clk_reg = <0xa03>;                // 时钟寄存器地址
			voltage = <0x47e>;                // 电压值（单位微伏）
			keep_count = <0x05>;              // 保持周期
			threshold = <0x1e 0x78>;          // 温度或负载阈值
			phandle = <0xa6>;
		};

		dvfs250_cfg {
			clk_freq = <0xee6b280>;           // 250MHz
			clk_parent = "fclk_div4";
			clkp_freq = <0x1dcd6500>;
			clk_reg = <0xa01>;
			voltage = <0x47e>;
			keep_count = <0x05>;
			threshold = <0x50 0xaa>;
			phandle = <0xa7>;
		};

		dvfs285_cfg {
			clk_freq = <0x1107a76d>;          // 285MHz
			clk_parent = "fclk_div7";
			clkp_freq = <0x1107a76d>;
			clk_reg = <0xe00>;
			voltage = <0x47e>;
			keep_count = <0x05>;
			threshold = <0x64 0xbe>;
			phandle = <0x14>;
		};

		dvfs400_cfg {
			clk_freq = <0x17d78400>;          // 400MHz
			clk_parent = "fclk_div5";
			clkp_freq = <0x17d78400>;
			clk_reg = <0xc00>;
			voltage = <0x47e>;
			keep_count = <0x05>;
			threshold = <0x98 0xcf>;
			phandle = <0x15>;
		};

		dvfs500_cfg {
			clk_freq = <0x1dcd6500>;          // 500MHz
			clk_parent = "fclk_div4";
			clkp_freq = <0x1dcd6500>;
			clk_reg = <0xa00>;
			voltage = <0x47e>;
			keep_count = <0x05>;
			threshold = <0xb4 0xdc>;
			phandle = <0x16>;
		};

		dvfs666_cfg {
			clk_freq = <0x27bc86aa>;          // 666MHz
			clk_parent = "fclk_div3";
			clkp_freq = <0x27bc86aa>;
			clk_reg = <0x800>;
			voltage = <0x47e>;
			keep_count = <0x05>;
			threshold = <0xd2 0xec>;
			phandle = <0x17>;
		};

		dvfs800_cfg {
			clk_freq = <0x2faf0800>;          // 800MHz
			clk_parent = "fclk_div2p5";
			clkp_freq = <0x2faf0800>;
			clk_reg = <0x600>;
			voltage = <0x47e>;
			keep_count = <0x05>;
			threshold = <0xe6 0xff>;
			phandle = <0x18>;
		};

		dvfs850_cfg {
			clk_freq = <0x326cef80>;          // 850MHz
			clk_parent = "gp0_pll";
			clkp_freq = <0x326cef80>;
			clk_reg = <0x200>;
			voltage = <0x47e>;
			keep_count = <0x05>;
			threshold = <0xe6 0xff>;
			phandle = <0xa8>;
		};
	};

	// CPU 频率下的能耗信息
	energy-costs {
		// LITTLE 核心能耗模型
		core-cost0 {
			busy-cost-data = <0x36 0x11 0x87 0x6e 0x10e 0xca 0x168 0x108 0x21c 0x18c 0x288 0x1d6 0x2f3 0x22d 0x330 0x26c 0x364 0x2bb 0x398 0x2f7 0x3cc 0x333 0x406 0x377 0x440 0x3a9 0x46e 0x3d0 0x4a8 0x418>;
			idle-cost-data = <0x05 0x00 0x00>;
			phandle = <0x23>;
		};
		// big 核心能耗模型
		core-cost1 {
			busy-cost-data = <0x21 0x04 0x53 0x17 0xa6 0x29 0xdd 0x36 0x14c 0x4e 0x18f 0x5c 0x1d1 0x74 0x1f7 0x87 0x217 0xa2 0x237 0xb8 0x257 0xe0 0x277 0x117>;
			idle-cost-data = <0x03 0x00 0x00>;
			phandle = <0x1f>;
		};
		// LITTLE 集群能耗模型
		cluster-cost0 {
			busy-cost-data = <0x36 0x11 0x87 0x14 0x10e 0x19 0x168 0x1b 0x21c 0x23 0x288 0x28 0x2f3 0x31 0x330 0x39 0x364 0x36 0x398 0x40 0x3cc 0x4b 0x406 0x56 0x440 0x61 0x46e 0x6c 0x4a8 0x6e>;
			idle-cost-data = <0x0a 0x0a 0x00>;
			phandle = <0x24>;
		};
		// big 集群能耗模型
		cluster-cost1 {
			busy-cost-data = <0x21 0x07 0x53 0x08 0xa6 0x09 0xdd 0x0a 0x14c 0x0d 0x18f 0x0f 0x1d1 0x13 0x1f7 0x17 0x217 0x1a 0x237 0x1f 0x257 0x24 0x277 0x2a>;
			idle-cost-data = <0x06 0x06 0x00>;
			phandle = <0x20>;
		};
	};

	// CPU 拓扑、频率、电源、时钟、EAS 能耗模型、空闲状态
	cpus {
		// 每个 CPU 的地址单元数量
		#address-cells = <0x01>;
		// CPU 节点不需要 size 单元
		#size-cells = <0x00>;
		// 节点引用句柄
		phandle = <0xa9>;

		// CPU 拓扑映射
		cpu-map {

			cluster0 {
				phandle = <0xaa>;
				// Cortex-A53 核心 0
				core0 {
					cpu = <0x19>;
				};
				// Cortex-A53 核心 1
				core1 {
					cpu = <0x1a>;
				};
			};

			cluster1 {
				phandle = <0xab>;
				// Cortex-A73 核心 0
				core0 {
					cpu = <0x1b>;
				};
				// Cortex-A73 核心 1
				core1 {
					cpu = <0x1c>;
				};
				// Cortex-A73 核心 2
				core2 {
					cpu = <0x1d>;
				};
				// Cortex-A73 核心 3
				core3 {
					cpu = <0x1e>;
				};
			};
		};
		// Cortex-A53 核心 0
		cpu@0 {
			device_type = "cpu";
			compatible = "arm,cortex-a53\0arm,armv8";
			// CPU ID
			reg = <0x00>;
			// 使用 PSCI 启动
			enable-method = "psci";
			// 引用 core-cost1 和 cluster-cost1
			sched-energy-costs = <0x1f 0x20>;
			// 时钟源引用
			clocks = <0x13 0x17 0x13 0x16 0x13 0xee>;
			clock-names = "core_clk\0low_freq_clk_parent\0high_freq_clk_parent";
			// DVFS 表引用
			operating-points-v2 = <0x21>;
			// 电源管理器引用
			cpu-supply = <0x22>;
			// 电压容差
			voltage-tolerance = <0x00>;
			 // 时钟切换延迟（单位微秒）
			clock-latency = <0xc350>;
			phandle = <0x19>;
		};
		// Cortex-A53 核心 1
		cpu@1 {
			device_type = "cpu";
			compatible = "arm,cortex-a53\0arm,armv8";
			reg = <0x01>;
			enable-method = "psci";
			sched-energy-costs = <0x1f 0x20>;
			clocks = <0x13 0x17 0x13 0x16 0x13 0xee>;
			clock-names = "core_clk\0low_freq_clk_parent\0high_freq_clk_parent";
			operating-points-v2 = <0x21>;
			cpu-supply = <0x22>;
			voltage-tolerance = <0x00>;
			clock-latency = <0xc350>;
			phandle = <0x1a>;
		};
		// Cortex-A73 核心 0
		cpu@100 {
			device_type = "cpu";
			compatible = "arm,cortex-a73\0arm,armv8";
			reg = <0x100>;
			enable-method = "psci";
			// 引用 core-cost0 和 cluster-cost0
			sched-energy-costs = <0x23 0x24>;
			clocks = <0x13 0xde 0x13 0xdd 0x13 0x00>;
			clock-names = "core_clk\0low_freq_clk_parent\0high_freq_clk_parent";
			operating-points-v2 = <0x25>;
			cpu-supply = <0x26>;
			voltage-tolerance = <0x00>;
			clock-latency = <0xc350>;
			phandle = <0x1b>;
		};
		// Cortex-A73 核心 1
		cpu@101 {
			device_type = "cpu";
			compatible = "arm,cortex-a73\0arm,armv8";
			reg = <0x101>;
			enable-method = "psci";
			sched-energy-costs = <0x23 0x24>;
			clocks = <0x13 0xde 0x13 0xdd 0x13 0x00>;
			clock-names = "core_clk\0low_freq_clk_parent\0high_freq_clk_parent";
			operating-points-v2 = <0x25>;
			cpu-supply = <0x26>;
			voltage-tolerance = <0x00>;
			clock-latency = <0xc350>;
			phandle = <0x1c>;
		};
		// Cortex-A73 核心 2
		cpu@102 {
			device_type = "cpu";
			compatible = "arm,cortex-a73\0arm,armv8";
			reg = <0x102>;
			enable-method = "psci";
			sched-energy-costs = <0x23 0x24>;
			clocks = <0x13 0xde 0x13 0xdd 0x13 0x00>;
			clock-names = "core_clk\0low_freq_clk_parent\0high_freq_clk_parent";
			operating-points-v2 = <0x25>;
			cpu-supply = <0x26>;
			voltage-tolerance = <0x00>;
			clock-latency = <0xc350>;
			phandle = <0x1d>;
		};
		// Cortex-A73 核心 3
		cpu@103 {
			device_type = "cpu";
			compatible = "arm,cortex-a73\0arm,armv8";
			reg = <0x103>;
			enable-method = "psci";
			sched-energy-costs = <0x23 0x24>;
			clocks = <0x13 0xde 0x13 0xdd 0x13 0x00>;
			clock-names = "core_clk\0low_freq_clk_parent\0high_freq_clk_parent";
			operating-points-v2 = <0x25>;
			cpu-supply = <0x26>;
			voltage-tolerance = <0x00>;
			clock-latency = <0xc350>;
			phandle = <0x1e>;
		};
		// 空闲状态定义
		idle-states {
			// 使用 PSCI 进入低功耗状态
			entry-method = "arm,psci";

			cpu-sleep-0 {
				compatible = "arm,idle-state";
				// CPU 层级 suspend 参数
				arm,psci-suspend-param = <0x10000>;
				local-timer-stop;
				// 进入延迟（8000us）
				entry-latency-us = <0x1f40>;
				// 退出延迟
				exit-latency-us = <0x1f40>;
				// 最小驻留时间（20000us）
				min-residency-us = <0x4e20>;
				phandle = <0xac>;
			};

			cluster-sleep-0 {
				compatible = "arm,idle-state";
				// 集群 suspend 参数
				arm,psci-suspend-param = <0x1010000>;
				local-timer-stop;
				// 进入延迟（9000us）
				entry-latency-us = <0x2328>;
				// 退出延迟
				exit-latency-us = <0x2328>;
				// 最小驻留时间（25000us）
				min-residency-us = <0x61a8>;
				phandle = <0xad>;
			};
		};
	};

	// 通用定时器
	timer {
		// 表示使用 ARMv7 架构的通用定时器（适用于 ARMv8 向下兼容）
		compatible = "arm,armv7-timer";
		interrupts = <0x01 0x0d 0xff08 0x01 0x0e 0xff08 0x01 0x0b 0xff08 0x01 0x0a 0xff08>;
	};

	// Meson 平台定时器
	timer_bc {
		// Meson 平台专用定时器驱动
		compatible = "arm, meson-bc-timer";
		reg = <0xffd0f190 0x04                // TimerF 控制寄存器
			0xffd0f194 0x04>;              // TimerF 值寄存器
		timer_name = "Meson TimerF";         // 定时器名称（用于日志或调试）
		clockevent-rating = <0x12c>;         // 定时器评分（300），用于 clockevent 选择
		clockevent-shift = <0x14>;           // 精度位移（20）
		clockevent-features = <0x23>;        // 支持的功能位（bitmask）
		interrupts = <0x00 0x3c 0x01>;        // 中断号 0x3c（60），类型为 level-high
		bit_enable = <0x10>;                 // 启用位（寄存器中的 bit 位置）
		bit_mode = <0x0c>;                   // 模式位（例如周期/单次）
		bit_resolution = <0x00>;            // 分辨率位（通常为 0 表示默认）
	};

	// 性能监控单元（PMU）
	arm_pmu {
		compatible = "arm,cortex-a15-pmu";   // 使用 Cortex-A15 PMU 驱动（适用于 A73/A53）
		clusterb-enabled;                    // 启用第二集群（big 核心）
		interrupts = <0x00 0x89 0x04         // LITTLE 核心 PMU 中断（137）
					0x00 0xab 0x04>;       // big 核心 PMU 中断（171）
		reg = <0xff634680 0x04               // LITTLE 核心 PMU 寄存器
			0xff6347c0 0x04>;             // big 核心 PMU 寄存器
		cpumasks = <0x03 0x3c>;              // LITTLE: 0x03 (CPU0/1), big: 0x3c (CPU2–5)
		relax-timer-ns = <0x989680>;         // 100ms（用于调度器放宽采样间隔）
		max-wait-cnt = <0x2710>;             // 最大等待计数（10000）
	};

	// GIC 中断控制器
	interrupt-controller@2c001000 {
		compatible = "arm,cortex-a15-gic\0arm,cortex-a9-gic";  // 支持 A15 和 A9 架构的 GIC
		#interrupt-cells = <0x03>;      // 中断描述格式为 <type number flags>
		#address-cells = <0x00>;        // 无子节点地址单元
		interrupt-controller;           // 声明为中断控制器
		reg = <0xffc01000 0x1000        // Distributor 寄存器
			0xffc02000 0x100>;       // CPU Interface 寄存器
		interrupts = <0x01 0x09 0xf04>; // SPI 中断号 9，flags 为 level-high
		phandle = <0x01>;               // 引用句柄
	};

	// 电源状态协调接口
	psci {
		compatible = "arm,psci-0.2";  // 使用 PSCI v0.2 协议
		method = "smc";               // 通过 SMC（Secure Monitor Call）调用
	};

	// Amlogic 平台电源管理器
	aml_pm {
		compatible = "amlogic, pm";     // Amlogic 专用电源管理驱动
		status = "okay";                // 启用状态
		device_name = "aml_pm";         // 设备名称
		debug_reg = <0xff8000a8>;       // 调试寄存器地址
		exit_reg = <0xff80023c>;        // 退出寄存器地址（可能用于 suspend/resume）
	};

	// 安全监控模块
	secmon {
		compatible = "amlogic, secmon";     // Amlogic 安全监控驱动
		memory-region = <0x27>;             // 保留内存区域（通常为 TZRAM）
		in_base_func = <0x82000020>;        // SMC 输入函数号
		out_base_func = <0x82000021>;       // SMC 输出函数号
		reserve_mem_size = <0x300000>;      // 预留内存大小（3MB）
		clear_range = <0x5100000 0x200000>; // 清除范围（地址 + 大小）
	};

	// 安全密钥服务接口
	securitykey {
		compatible = "aml, securitykey";    // Amlogic 安全密钥驱动
		storage_query = <0x82000060>;       // 查询密钥
		storage_read = <0x82000061>;        // 读取密钥
		storage_write = <0x82000062>;       // 写入密钥
		storage_tell = <0x82000063>;        // 获取密钥位置
		storage_verify = <0x82000064>;      // 验证密钥
		storage_status = <0x82000065>;      // 获取状态
		storage_list = <0x82000067>;        // 列出密钥
		storage_remove = <0x82000068>;      // 删除密钥
		storage_in_func = <0x82000023>;     // 输入函数
		storage_out_func = <0x82000024>;    // 输出函数
		storage_block_func = <0x82000025>;  // 块操作函数
		storage_size_func = <0x82000027>;   // 获取密钥大小
		storage_set_enctype = <0x8200006a>; // 设置加密类型
		storage_get_enctype = <0x8200006b>; // 获取加密类型
		storage_version = <0x8200006c>;     // 获取版本信息
	};

	// Message Handling Unit（CPU ↔ SCP 通信）
	mhu@c883c400 {
		compatible = "amlogic, meson_mhu";         // Amlogic MHU 驱动
		reg = <0xff63c400 0x4c                      // MHU 控制寄存器
			0xfffe7000 0x800>;                   // SCP 通信区域
		interrupts = <0x00 0xd1 0x01                // 中断 209（低通道）
					0x00 0xd2 0x01>;              // 中断 210（高通道）
		#mbox-cells = <0x01>;                       // 每个邮箱使用一个 cell
		mbox-names = "cpu_to_scp_low\0cpu_to_scp_high";  // 邮箱名称
		mboxes = <0x28 0x00 0x28 0x01>;             // 邮箱通道引用
		phandle = <0x28>;
	};

	// CPU I/O 映射区域
	cpu_iomap {
		compatible = "amlogic, iomap";
		#address-cells = <0x01>;
		#size-cells = <0x01>;
		ranges;

		io_cbus_base     { reg = <0xffd00000 0x26000>; };
		io_apb_base      { reg = <0xffe01000 0x7f000>; };
		io_aobus_base    { reg = <0xff800000 0xb000>; };
		io_vapb_base     { reg = <0xff900000 0x50000>; };
		io_hiu_base      { reg = <0xff63c000 0x2000>; };
	};

	// 固定晶振时钟源
	xtal-clk {
		compatible = "fixed-clock";
		clock-frequency = <0x16e3600>;         // 24MHz（0x16e3600）
		clock-output-names = "xtal";           // 时钟名称
		#clock-cells = <0x00>;                 // 无参数
		phandle = <0x2d>;
	};

	// 实时时钟模块
	rtc {
		compatible = "amlogic, aml_vrtc";
		alarm_reg_addr = <0xff8000a8>;         // 闹钟寄存器地址
		timer_e_addr = <0xffd0f188>;           // TimerE 地址
		init_date = "2019/01/01";              // 初始日期
		status = "okay";
	};

	// CPU 信息接口
	cpu_info {
		compatible = "amlogic, cpuinfo";
		status = "okay";
		cpuinfo_cmd = <0x82000044>;            // SMC 命令号，用于获取 CPU 信息
	};

	// 系统重启与关机控制器
	aml_reboot {
		compatible = "aml, reboot";
		sys_reset = <0x84000009>;              // SMC 命令号：重启
		sys_poweroff = <0x84000008>;           // SMC 命令号：关机
	};

	// 视频处理单元
	vpu {
		compatible = "amlogic, vpu-g12b";      // G12B 平台 VPU 驱动
		dev_name = "vpu";
		status = "okay";
		clocks = <0x13 0x95 0x13 0x4c 0x13 0x87 0x13 0x8b 0x13 0x8c>;  // 时钟源引用
		clock-names = "vapb_clk\0vpu_intr_gate\0vpu_clk0\0vpu_clk1\0vpu_clk";
		clk_level = <0x07>;                    // 时钟等级（性能等级）
	};

	// ethernet@ff3f0000 节点是 Amlogic G12A 平台上的以太网控制器
	ethernet@ff3f0000 {
		compatible = "amlogic, g12a-eth-dwmac", "snps,dwmac";  // 使用 Amlogic 定制的 DWMAC 驱动
		reg = <0xff3f0000 0x10000        // eth_base: MAC 寄存器区域
			0xff634540 0x08           // eth_cfg: 配置寄存器
			0xff64c000 0xa0           // eth_pll: PLL 控制寄存器
			0xffd01008 0x04>;         // eth_reset: 复位寄存器
		reg-names = "eth_base", "eth_cfg", "eth_pll", "eth_reset";

		interrupts = <0x00 0x08 0x01>;   // SPI 中断号 8，类型为 level-high
		interrupt-names = "macirq";     // MAC 中断名称

		status = "okay";                // 启用设备

		clocks = <0x13 0x38>;           // 时钟控制器引用（ethclk81）
		clock-names = "ethclk81";       // 时钟名称

		pll_val = <0x09c0040a 0x927e0000 0xac5f49e5>;  // PLL 初始化值（用于 PHY 时钟）
		analog_val = <0x20200000 0x0000c000 0x23>;     // 模拟电路配置（PHY 校准相关）

		pinctrl-names = "external_eth_pins";          // 引脚配置名称
		pinctrl-0 = <0x29>;                           // 引脚控制器引用

		mc_val = <0x1621>;            // MAC 控制寄存器值（可能用于 TX/RX 配置）
		cali_val = <0x60000>;         // PHY 校准值（用于 RX/TX 延迟调整）
		rx_delay = <0x01>;            // 接收延迟（单位可能为 ns 或寄存器位）
		auto_cali_idx = <0x26>;       // 自动校准索引（用于动态 PHY 调整）

		internal_phy = <0x00>;        // 使用外部 PHY（0 表示关闭内部 PHY）

		phandle = <0xae>;             // 节点引用句柄
	};

	// AO（Always-On）域引脚控制器配置，涵盖了 UART、I²C、PWM、CEC、JTAG、红外、SPDIF 等功能的引脚复用设置。这是系统低功耗域中最关键的引脚管理模块之一。
	pinctrl@ff800014 {
		// G12A AO 域 pinctrl 驱动
		compatible = "amlogic,meson-g12a-aobus-pinctrl";
		#address-cells = <0x01>;
		#size-cells = <0x01>;
		ranges;
		phandle = <0xaf>;

		// AO GPIO 控制器
		ao-bank@ff800014 {
			reg = <0xff800014 0x08        // mux 控制寄存器
				0xff800024 0x14        // gpio 状态寄存器
				0xff80001c 0x08>;      // drive-strength 寄存器
			reg-names = "mux", "gpio", "drive-strength";
			gpio-controller;
			#gpio-cells = <0x02>;         // <pin offset, flags>
			phandle = <0x61>;
		};

		// UART 配置：ao_uart、ao_b_uart、sd_to_ao_uart_pins、sd_to_ao_uart_clr_pins
		// I²C 配置: ao_i2c_pins1、ao_i2c_pins2、ao_i2c_slave_pins
		// PWM 配置：pwm_ao_a、pwm_ao_a_hiz、pwm_ao_b、pwm_ao_c_pins1、pwm_ao_c_pins2、pwm_ao_c_hiz、pwm_ao_d_pins1、pwm_ao_d_pins2、pwm_ao_d_pins3、pwm_a_e2
		// CEC（HDMI 控制）配置：ao_ceca、ao_cecb
		// JTAG 配置：jtag_apao_pin
		// 红外与遥控配置；remote_pin、irblaster_pin、irblaster_pin1
		// SPDIF 配置：spdifout、spdifout_a_mute

		ao_uart {
			phandle = <0xb0>;
			// 引脚复用配置
			mux {
				groups = "uart_ao_tx_a\0uart_ao_rx_a";
				function = "uart_ao_a";
			};
		};

		ao_b_uart {
			phandle = <0x35>;

			mux {
				groups = "uart_ao_tx_b_2\0uart_ao_rx_b_3";
				function = "uart_ao_b";
			};
		};

		ao_i2c_pins1 {
			phandle = <0xb1>;

			mux {
				groups = "i2c_ao_sck\0i2c_ao_sda";
				function = "i2c_ao";
				bias-pull-up;
				drive-strength = <0x02>;
			};
		};

		ao_i2c_pins2 {
			phandle = <0xb2>;

			mux {
				groups = "i2c_ao_sck_e\0i2c_ao_sda_e";
				function = "i2c_ao";
				bias-pull-up;
				drive-strength = <0x02>;
			};
		};

		ao_i2c_slave_pins {
			phandle = <0x34>;

			mux {
				groups = "i2c_ao_slave_sck\0i2c_ao_slave_sda";
				function = "i2c_ao_slave";
			};
		};

		pwm_ao_a {
			phandle = <0xb3>;

			mux {
				groups = "pwm_ao_a";
				function = "pwm_ao_a";
			};
		};

		pwm_ao_a_hiz {
			phandle = <0xb4>;

			mux {
				groups = "pwm_ao_a_hiz";
				function = "pwm_ao_a";
			};
		};

		pwm_ao_b {
			phandle = <0xb5>;

			mux {
				groups = "pwm_ao_b";
				function = "pwm_ao_b";
			};
		};

		pwm_ao_c_pins1 {
			phandle = <0xb6>;

			mux {
				groups = "pwm_ao_c_4";
				function = "pwm_ao_c";
			};
		};

		pwm_ao_c_pins2 {
			phandle = <0xb7>;

			mux {
				groups = "pwm_ao_c_6";
				function = "pwm_ao_c";
			};
		};

		pwm_ao_c_hiz {
			phandle = <0xb8>;

			mux {
				groups = "pwm_ao_c_hiz_4";
				function = "pwm_ao_c";
			};
		};

		pwm_ao_d_pins1 {
			phandle = <0xb9>;

			mux {
				groups = "pwm_ao_d_5";
				function = "pwm_ao_d";
			};
		};

		pwm_ao_d_pins2 {
			phandle = <0xba>;

			mux {
				groups = "pwm_ao_d_10";
				function = "pwm_ao_d";
			};
		};

		pwm_ao_d_pins3 {
			phandle = <0x6f>;

			mux {
				groups = "pwm_ao_d_e";
				function = "pwm_ao_d";
			};
		};

		ao_ceca {
			phandle = <0xbb>;

			mux {
				groups = "cec_ao_a";
				function = "cec_ao";
			};
		};

		ao_cecb {
			phandle = <0xbc>;

			mux {
				groups = "cec_ao_b";
				function = "cec_ao";
			};
		};

		pwm_a_e2 {
			phandle = <0x71>;

			mux {
				groups = "pwm_a_e2";
				function = "pwm_a_gpioe";
			};
		};

		jtag_apao_pin {
			phandle = <0x2e>;

			mux {
				groups = "jtag_a_tdi\0jtag_a_tdo\0jtag_a_clk\0jtag_a_tms";
				function = "jtag_a";
			};
		};

		sd_to_ao_uart_clr_pins {
			phandle = <0x5c>;

			mux {
				groups = "GPIOAO_0\0GPIOAO_1";
				function = "gpio_aobus";
			};
		};

		sd_to_ao_uart_pins {
			phandle = <0x5e>;

			mux {
				groups = "uart_ao_tx_a\0uart_ao_rx_a";
				function = "uart_ao_a";
				bias-pull-up;
				input-enable;
			};
		};

		remote_pin {
			phandle = <0x43>;

			mux {
				groups = "remote_input_ao";
				function = "remote_input_ao";
			};
		};

		irblaster_pin {
			phandle = <0xbd>;

			mux {
				groups = "remote_out_ao";
				function = "remote_out_ao";
			};
		};

		irblaster_pin1 {
			phandle = <0xbe>;

			mux {
				groups = "remote_out_ao9";
				function = "remote_out_ao";
			};
		};

		spdifout {
			phandle = <0x40>;

			mux {
				groups = "spdif_out_ao";
				function = "spdif_out_ao";
			};
		};

		spdifout_a_mute {
			phandle = <0x41>;

			mux {
				groups = "GPIOAO_10";
				function = "gpio_aobus";
			};
		};
	};

	// G12A 平台的主外设引脚控制器（PERIPHS 域），负责管理除 AO 域外的大部分 GPIO 和复用功能。它支持 SD/eMMC、I²C、PWM、SPI、UART、HDMI、Ethernet、音频等模块的引脚配置。包括存储接口（eMMC/SD/NAND/SDIO）、通信接口（I²C/SPI/UART）、音视频接口（HDMI/CEC/TDM/SPDIF）、控制接口（PWM/JTAG）、网络接口（Ethernet）、红外遥控与麦克风输入
	pinctrl@ff634480 {
		compatible = "amlogic,meson-g12a-periphs-pinctrl";
		#address-cells = <0x01>;
		#size-cells = <0x01>;
		ranges;
		phandle = <0xbf>;

		banks@ff6346c0 {
			reg = <0xff6346c0 0x40 0xff6344e8 0x18 0xff634520 0x18 0xff634440 0x4c 0xff634740 0x1c>;
			reg-names = "mux\0pull\0pull-enable\0gpio\0drive-strength";
			gpio-controller;
			#gpio-cells = <0x02>;
			phandle = <0x2c>;
		};

		emmc_clk_cmd_pins {
			phandle = <0x56>;

			mux {
				groups = "emmc_clk\0emmc_cmd";
				function = "emmc";
				input-enable;
				bias-pull-up;
				drive-strength = <0x03>;
			};
		};

		emmc_conf_pull_up {
			phandle = <0x57>;

			mux {
				groups = "emmc_nand_d7\0emmc_nand_d6\0emmc_nand_d5\0emmc_nand_d4\0emmc_nand_d3\0emmc_nand_d2\0emmc_nand_d1\0emmc_nand_d0\0emmc_clk\0emmc_cmd";
				function = "emmc";
				input-enable;
				bias-pull-up;
				drive-strength = <0x03>;
			};
		};

		emmc_conf_pull_done {
			phandle = <0x58>;

			mux {
				groups = "emmc_nand_ds";
				function = "emmc";
				input-enable;
				bias-pull-down;
				drive-strength = <0x03>;
			};
		};

		sd_clk_cmd_pins {
			phandle = <0x5a>;

			mux {
				groups = "sdcard_cmd_c\0sdcard_clk_c";
				function = "sdcard";
				input-enable;
				bias-pull-up;
				drive-strength = <0x03>;
			};
		};

		sd_all_pins {
			phandle = <0x59>;

			mux {
				groups = "sdcard_d0_c\0sdcard_d1_c\0sdcard_d2_c\0sdcard_d3_c\0sdcard_cmd_c\0sdcard_clk_c";
				function = "sdcard";
				input-enable;
				bias-pull-up;
				drive-strength = <0x03>;
			};
		};

		sd_1bit_pins {
			phandle = <0x5b>;

			mux {
				groups = "sdcard_d0_c\0sdcard_cmd_c\0sdcard_clk_c";
				function = "sdcard";
				input-enable;
				bias-pull-up;
				drive-strength = <0x03>;
			};
		};

		ao_to_sd_uart_pins {
			phandle = <0x5d>;

			mux {
				groups = "uart_ao_tx_a_c3\0uart_ao_rx_a_c2";
				function = "uart_ao_a_ee";
				bias-pull-up;
				input-enable;
			};
		};

		sdio_clk_cmd_pins {
			phandle = <0x60>;

			mux {
				groups = "sdio_clk\0sdio_cmd";
				function = "sdio";
				input-enable;
				bias-pull-up;
				drive-strength = <0x03>;
			};
		};

		sdio_all_pins {
			phandle = <0x5f>;

			mux {
				groups = "sdio_d0\0sdio_d1\0sdio_d2\0sdio_d3\0sdio_clk\0sdio_cmd";
				function = "sdio";
				input-enable;
				bias-pull-up;
				drive-strength = <0x03>;
			};
		};

		all_nand_pins {
			phandle = <0x62>;

			mux {
				groups = "emmc_nand_d0\0emmc_nand_d1\0emmc_nand_d2\0emmc_nand_d3\0emmc_nand_d4\0emmc_nand_d5\0emmc_nand_d6\0emmc_nand_d7\0nand_ce0\0nand_ale\0nand_cle\0nand_wen_clk\0nand_ren_wr\0nand_rb0";
				function = "nand";
