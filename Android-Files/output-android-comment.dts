	// Amlogic专用CPU调频控制器
	cpufreq-meson {
		compatible = "amlogic, cpufreq-meson";
		status = "okay";
	};

	// 图形传感器
	sensor {
		compatible = "soc, sensor";
		status = "disabled";
		sensor-name = "os08a10";
		pinctrl-names = "default";
		pinctrl-0 = <0xa3>;
		clocks = <0x13 0xd7>;
		clock-names = "g12a_24m";
		reset = <0x2c 0x0d 0x00>;
		ir_cut_gpio = <0x2c 0x0c 0x00 0x2c 0x08 0x00>;
		phandle = <0x11f>;
	};

	// 图像质量（IQ）模块相关的硬件组件
	iq {
		compatible = "soc, iq";
		status = "disabled";
		sensor-name = "os08a10";
		phandle = <0x120>;
	};

